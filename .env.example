# Backend environment template (production-safe defaults)
APP_NAME=PA.ADS MVP - AI News Feed
APP_ENV=production
DEBUG=false

# Core infrastructure
DATABASE_URL=postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DB>
REDIS_URL=redis://default:<PASSWORD>@<HOST>:<PORT>/0
CELERY_BROKER_URL=redis://default:<PASSWORD>@<HOST>:<PORT>/0
CELERY_RESULT_BACKEND=redis://default:<PASSWORD>@<HOST>:<PORT>/1

# Security
JWT_SECRET_KEY=<RANDOM_64_PLUS_CHARS>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
SESSION_SECRET_KEY=<RANDOM_64_PLUS_CHARS>

# Frontend URLs for OAuth callback redirects
OAUTH_FRONTEND_SUCCESS_URL=https://<YOUR-VERCEL-DOMAIN>
OAUTH_FRONTEND_ERROR_URL=https://<YOUR-VERCEL-DOMAIN>

# OAuth providers
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# Email delivery (pick Resend or SMTP)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@your-domain.com
SMTP_USE_TLS=true

# Auth flows
AUTH_VERIFICATION_CODE_TTL_MINUTES=10
AUTH_VERIFICATION_MAX_ATTEMPTS=5
AUTH_DEBUG_RETURN_CODE=false
PASSWORD_RESET_CODE_TTL_MINUTES=15
PASSWORD_RESET_MAX_ATTEMPTS=5

# Network and host restrictions
CORS_ALLOW_ORIGINS=https://<YOUR-VERCEL-DOMAIN>,https://www.<YOUR-VERCEL-DOMAIN>
CORS_ALLOW_ORIGIN_REGEX=
TRUSTED_HOSTS=*

# AI/news APIs (set only those you use)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
NEWS_API_KEY=
YOUTUBE_API_KEY=
YOUTUBE_REGION_CODE=US
